# ==============================================================================
# 1. CẤU HÌNH DỊCH VỤ DATABASE POSTGRESQL (DOCKER COMPOSE)
# ==============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secret_password
POSTGRES_DB=food_review
POSTGRES_PORT=5432

# ==============================================================================
# 2. CẤU HÌNH BACKEND API (FASTAPI)
# ==============================================================================
PROJECT_NAME="Food Review API"
API_V1_STR="/api"
ENV="development"
ENABLE_DB_FALLBACK=True




# CORS Origins - Hỗ trợ cả JSON Array hoặc Comma-separated list các URL được phép truy cập
CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000", "http://127.0.0.1:5173"]'

#-------------------------------------------------------------------------------
# KẾT NỐI DATABASE: Chọn 1 trong 2 cấu hình dưới đây tùy theo môi trường chạy
#-------------------------------------------------------------------------------

# [A] Kịch bản Local (Tuần 1): FastAPI chạy bằng Uvicorn trên máy local chọc vào DB Docker
# (Sử dụng localhost vì Docker map port 5432 ra máy host)
DATABASE_URL="postgresql://postgres:postgres_secret_password@localhost:5432/food_review"

# [B] Kịch bản Docker Network (Tuần 2): FastAPI được đóng gói Docker chạy chung mạng với DB
# (Sử dụng tên dịch vụ 'db' thay cho 'localhost' và cổng 5432 nội bộ)
# DATABASE_URL="postgresql://postgres:postgres_secret_password@db:5432/food_review"

# ==============================================================================
# 3. CẤU HÌNH CLOUDFLARE R2 CLOUD STORAGE
# ==============================================================================
CLOUDFLARE_R2_ACCOUNT_ID="your_cloudflare_account_id_here"
CLOUDFLARE_R2_ACCESS_KEY_ID="your_cloudflare_access_key_id_here"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_cloudflare_secret_access_key_here"
CLOUDFLARE_R2_BUCKET_NAME="food-review-bucket"
CLOUDFLARE_R2_PUBLIC_URL="https://pub-youraccountid.r2.dev"
